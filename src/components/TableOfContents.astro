---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show if 3+ headings exist
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const show = filtered.length >= 3;
---

{show && (
  <nav class="toc" aria-label="Table of contents">
    <p class="toc__title">On this page</p>
    <ul class="toc__list" role="list">
      {filtered.map((heading) => (
        <li class:list={['toc__item', { 'toc__item--nested': heading.depth === 3 }]}>
          <a href={`#${heading.slug}`} class="toc__link">{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .toc__title {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--color-border);
  }

  .toc__item {
    padding-left: 1rem;
  }

  .toc__item--nested {
    padding-left: 2rem;
  }

  .toc__link {
    display: block;
    padding: 0.25rem 0;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc__link:hover {
    color: var(--color-accent);
  }
</style>
