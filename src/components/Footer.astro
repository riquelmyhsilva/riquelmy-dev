---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <p class="footer__copy">&copy; {currentYear} Riquelmy. All rights reserved.</p>
    </div>
    <div class="footer__right">
      <nav class="footer__links" aria-label="Footer links">
        <a href="/rss.xml" class="footer__link" aria-label="RSS Feed">RSS</a>
        <a href="https://github.com" class="footer__link" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">GitHub</a>
        <a href="https://linkedin.com" class="footer__link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">LinkedIn</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 5rem;
    padding: 2rem 0;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 640px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer__links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer__link:hover {
    color: var(--color-text);
  }
</style>
