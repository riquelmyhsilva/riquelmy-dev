---
interface Props {
  type?: 'note' | 'warning' | 'tip';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const labels: Record<string, string> = {
  note: 'Note',
  warning: 'Warning',
  tip: 'Tip',
};

const displayTitle = title || labels[type];
---

<aside class={`callout callout--${type}`} role="note" aria-label={displayTitle}>
  <div class="callout__header">
    <svg class="callout__icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
      {type === 'note' && (
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      )}
      {type === 'warning' && (
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
      )}
      {type === 'tip' && (
        <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
      )}
    </svg>
    <span class="callout__title">{displayTitle}</span>
  </div>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-left: 3px solid;
    background-color: var(--color-surface);
  }

  .callout--note {
    border-left-color: var(--color-accent);
  }

  .callout--warning {
    border-left-color: #d97706;
  }

  .callout--tip {
    border-left-color: #22c55e;
  }

  .callout__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .callout--note .callout__header {
    color: var(--color-accent);
  }

  .callout--warning .callout__header {
    color: #d97706;
  }

  .callout--tip .callout__header {
    color: #22c55e;
  }

  .callout__icon {
    flex-shrink: 0;
  }

  .callout__body {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .callout__body :global(p) {
    margin: 0;
  }

  .callout__body :global(p + p) {
    margin-top: 0.5rem;
  }
</style>
