---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@utils/readingTime';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog | Riquelmy"
  description="Technical articles on data science, machine learning, business intelligence, programming, and infrastructure."
>
  <section class="blog-page container-main">
    <header class="blog-page__header">
      <h1 class="blog-page__title">Blog</h1>
      <p class="blog-page__desc">
        Technical writing on data science, engineering, and software development.
      </p>
    </header>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="blog-page__filters" id="tag-filters" role="group" aria-label="Filter articles by tag">
        <button class="filter-tag filter-tag--active" data-tag="all" type="button">All</button>
        {allTags.map((tag) => (
          <button class="filter-tag" data-tag={tag} type="button">{tag}</button>
        ))}
      </div>
    )}

    <!-- Article list -->
    <div class="blog-page__list" id="articles-list">
      {posts.map((post) => (
        <div class="blog-page__item" data-tags={post.data.tags.join(',')}>
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body ?? '')}
            slug={post.id}
          />
        </div>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="blog-page__empty">No articles published yet.</p>
    )}
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    var filters = document.getElementById('tag-filters');
    var items = document.querySelectorAll('#articles-list .blog-page__item');
    if (!filters) return;

    // Read initial tag from URL
    var params = new URLSearchParams(window.location.search);
    var initial = params.get('tag') || 'all';

    function activate(tag) {
      // Update buttons
      filters.querySelectorAll('.filter-tag').forEach(function(btn) {
        btn.classList.toggle('filter-tag--active', btn.getAttribute('data-tag') === tag);
      });
      // Filter articles
      items.forEach(function(item) {
        if (tag === 'all') {
          item.style.display = '';
        } else {
          var tags = (item.getAttribute('data-tags') || '').split(',');
          item.style.display = tags.indexOf(tag) !== -1 ? '' : 'none';
        }
      });
      // Update URL without reload
      var url = new URL(window.location);
      if (tag === 'all') {
        url.searchParams.delete('tag');
      } else {
        url.searchParams.set('tag', tag);
      }
      history.replaceState(null, '', url);
    }

    activate(initial);

    filters.addEventListener('click', function(e) {
      var btn = e.target.closest('.filter-tag');
      if (btn) activate(btn.getAttribute('data-tag'));
    });
  })();
</script>

<style>
  .blog-page {
    padding: 3rem 0 2rem;
  }

  .blog-page__header {
    margin-bottom: 2rem;
  }

  .blog-page__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .blog-page__desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .blog-page__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-tag {
    padding: 0.3rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: var(--font-sans);
  }

  .filter-tag:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .filter-tag--active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .filter-tag--active:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: #fff;
  }

  .blog-page__list {
    display: grid;
    gap: 1rem;
  }

  .blog-page__empty {
    font-size: 1rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 3rem 0;
  }
</style>
